# --- Secrets & local config (never commit) ---
.env
.env.*
!.env.example
config/customer_mapping.yaml
config/warranty_rules.yaml
config/contract_pricing.yaml
config/business_rules.yaml
config/technicians.yaml
config/technicians.draft.yaml
config/*.local.yaml

# --- Radix token cache ---
.cache/
*.token.json

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# --- Data / dumps / exports ---
data/
exports/
*.sqlite
*.dump
*.bak
pg_dumps/

# --- FleetMgmt MSSQL runtime logs + restore sources (keep dirs, not contents) ---
database/fleetmgmt/logs/*
!database/fleetmgmt/logs/.gitkeep
database/fleetmgmt/backups/*
!database/fleetmgmt/backups/.gitkeep
database/fleetmgmt/import/*
!database/fleetmgmt/import/.gitkeep
# SQL data extracts pulled from the transfer (missing_data, schema dumps, samples)
database/fleetmgmt/data/*
!database/fleetmgmt/data/.gitkeep
# Re-import working set (filtered SQL + multi-GB TSVs)
database/fleetmgmt/work/*
!database/fleetmgmt/work/.gitkeep

# --- Streamlit ---
.streamlit/secrets.toml

# --- IDE / OS ---
.idea/
.vscode/
.DS_Store
Thumbs.db

# --- Claude Code (local settings only; shared config may be committed) ---
.claude/settings.local.json
.claude/*.local.json
