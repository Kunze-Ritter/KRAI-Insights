# ============================================================================
# krai-insights — Environment Configuration
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in. NEVER commit the real `.env`.
#   cp .env.example .env
# ============================================================================

# --- App ---------------------------------------------------------------------
APP_ENV=dev                 # dev | prod
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
# Dashboard-Passwort: leer = offen (Dev). Vor Mitarbeiter-Rollout setzen, dann
# `docker compose up -d app` (Container neu, damit .env neu geladen wird).
# Langfristiges Ziel: Microsoft-SSO (Entra ID) statt geteiltem Passwort.
DASHBOARD_PASSWORD=

# --- Insights DB (own PostgreSQL 16 container — the ONLY DB we write to) -----
INSIGHTS_DB_HOST=localhost
INSIGHTS_DB_PORT=5433      # host port; container listens on 5432 (see compose)
INSIGHTS_DB_NAME=krai_insights
INSIGHTS_DB_USER=insights
INSIGHTS_DB_PASSWORD=CHANGE_ME_STRONG_INSIGHTS_PASSWORD

# ============================================================================
# SOURCE SYSTEMS — strictly READ-ONLY. krai-insights never mutates these.
# When the app runs inside Docker and a source DB runs on the host, use
# `host.docker.internal` as the host instead of `localhost`.
# ============================================================================

# --- FleetMgmt (MSSQL, ~62M rows) — runs as a container in docker-compose.yml -
# MSSQL_SA_PASSWORD is the SA password of the krai-fleetmgmt-mssql container.
# FLEETMGMT_MSSQL_USER/PASSWORD is the read-only login the app connects with.
MSSQL_SA_PASSWORD=
FLEETMGMT_MSSQL_HOST=host.docker.internal
FLEETMGMT_MSSQL_PORT=1433
FLEETMGMT_MSSQL_DB=DevFleetMgmt
FLEETMGMT_MSSQL_USER=krai_readonly
FLEETMGMT_MSSQL_PASSWORD=
FLEETMGMT_MSSQL_DRIVER=ODBC Driver 18 for SQL Server
FLEETMGMT_MSSQL_TRUST_CERT=true    # set true for self-signed server certs
# Restore/import source dirs mounted read-only (/backups, /import). Defaults to
# the local placeholders under database/fleetmgmt/ if unset; point at real paths
# (e.g. the transfer backup dir and C:\Transferr) when restoring.
FLEETMGMT_BACKUP_DIR=./database/fleetmgmt/backups
FLEETMGMT_IMPORT_DIR=./database/fleetmgmt/import

# --- KRAI PostgreSQL (krai_pm schema) ---------------------------------------
# On the shared krai-network use the container name krai-postgres-prod;
# without the shared network use host.docker.internal.
KRAI_PG_HOST=krai-postgres-prod
KRAI_PG_PORT=5432
KRAI_PG_DB=krai
KRAI_PG_USER=krai_readonly
KRAI_PG_PASSWORD=
KRAI_PG_SCHEMA=krai_pm

# --- Radix RxPlusService API -------------------------------------------------
# Token from /api/authenticateApps/login/apps is valid ~1h and is refreshed
# automatically by RadixAuthManager. Do NOT set a static bearer token here.
RADIX_API_URL=https://radix.kunze-ritter.de/IM.RxPlusService.Api
RADIX_API_LANGUAGE=DE
RADIX_USERNAME=
RADIX_PASSWORD_BASE64=
RADIX_CLIENT_CODE=
RADIX_LICENSE_ID=
RADIX_TOKEN_CACHE_PATH=.cache/radix_token.json
RADIX_TOKEN_REFRESH_MARGIN_SECONDS=60   # refresh when <Ns of lifetime remain

# --- LLM provider for the KI-Agent / "Fragen" page --------------------------
# "ollama" (local, default) or "openrouter" (hosted, stronger free models).
# With openrouter, the agent automatically FALLS BACK to Ollama if OpenRouter is
# rate-limited/unavailable, so it always stays up.
LLM_PROVIDER=ollama

# --- Ollama (local LLM) ------------------------------------------------------
# Pick ONE base URL:
#   - Windows-native Ollama:  http://host.docker.internal:11434
#     (set OLLAMA_HOST=0.0.0.0:11434 on Windows so the container can reach it)
#   - bundled ollama (compose profile "agent"): http://ollama:11434
#   - shared KRAI stack ollama: http://krai-ollama-prod:11434
# Model must support tool-calling (e.g. qwen2.5, qwen2.5-coder, llama3.1).
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b

# --- OpenRouter (optional hosted backend; set LLM_PROVIDER=openrouter) -------
# Get a key at https://openrouter.ai/settings/keys . Free models share upstream
# capacity and are often briefly rate-limited (HTTP 429) — the Ollama fallback
# covers that. Model MUST support tool-calling.
# Responsive free tool-calling models (2026-05): z-ai/glm-4.5-air:free (fast,
# good German), openai/gpt-oss-20b:free, openai/gpt-oss-120b:free. Note:
# meta-llama/llama-3.3-70b-instruct:free is strong but frequently 429-saturated.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Business rules ----------------------------------------------------------
# Warranty standard confirmed: 365 days flat. Per-manufacturer special cases
# live in config/warranty_rules.yaml (overrides this default).
WARRANTY_DEFAULT_DAYS=365
CUSTOMER_MAPPING_PATH=config/customer_mapping.yaml
WARRANTY_RULES_PATH=config/warranty_rules.yaml

# --- VBM Crawler bridge (KRAI-Crawler-VBM Schwester-Repo) -------------------
# Brücke zum Schwester-Repo KRAI-Crawler-VBM, das Toner/Drum/Developer-Yields
# direkt von den Hersteller-Websites zieht.
#
# Zwei Setup-Varianten:
#
#  A) DOCKER: VBM_CRAWLER_OUTPUT_HOST = Pfad auf dem Host zum
#     KRAI-Crawler-VBM/output/-Verzeichnis. docker-compose mountet diesen
#     read-only nach /srv/vbm-crawler/. Dann VBM_CRAWLER_OUTPUT_DIR auf den
#     Container-Pfad setzen:
#        VBM_CRAWLER_OUTPUT_HOST=C:\Github\KRAI-Crawler-VBM\output
#        VBM_CRAWLER_OUTPUT_DIR=/srv/vbm-crawler
#
#  B) HOST/VENV: VBM_CRAWLER_OUTPUT_DIR leer lassen, dann nimmt der Extractor
#     den Sibling-Default (../KRAI-Crawler-VBM/output/).
#
# Bleibt VBM_CRAWLER_OUTPUT_HOST leer, mountet docker-compose
# ./.cache/vbm-crawler/ als Platzhalter (verhindert Mount-Fehler), und der
# Loader meldet "Master nicht gefunden" - kein Problem, einfach nicht aufrufen.
VBM_CRAWLER_OUTPUT_HOST=
VBM_CRAWLER_OUTPUT_DIR=

# --- Reverse-proxy basic auth (Phase 6 deploy; optional in dev) -------------
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- Rollout: Cloudflare Tunnel + Access (SSO) — siehe docs/deployment.md ----
# Host-Adresse, an die der App-Port (8501) gebunden wird. Default 127.0.0.1 =
# nur lokal erreichbar (sicher; Zugriff laeuft ueber den Tunnel). Fuer direkten
# LAN-Zugriff in der Uebergangszeit auf 0.0.0.0 setzen.
APP_BIND_HOST=127.0.0.1
# Tunnel-Token aus dem Cloudflare-Zero-Trust-Dashboard (Tunnel anlegen -> Token).
# Nur noetig, wenn der Tunnel laeuft: docker compose --profile tunnel up -d cloudflared
CLOUDFLARE_TUNNEL_TOKEN=
