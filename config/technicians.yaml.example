# Techniker-Aliase für das Service-Dashboard.
#
# Radix liefert nur eine pseudonyme employee_id. Hier ordnest du sie deinen
# Technikern zu (Kürzel + optional Name), damit das Dashboard echte Kürzel statt
# IDs zeigt. Fehlt diese Datei oder ein Eintrag, fällt das Dashboard auf die
# employee_id zurück (DSGVO-unkritisch).
#
# Vorschlag: `python scripts/seed_technicians.py` schreibt einen Entwurf
# (config/technicians.draft.yaml), indem es die Kürzel aus dem Call-Log der
# Tickets je employee_id rät. Entwurf prüfen, korrigieren, nach
# config/technicians.yaml kopieren, dann:
#   docker exec krai-insights-app python -m insights.etl.load --technicians
#
# Format: employee_id -> Kürzel  ODER  employee_id -> { kuerzel, name }

technicians:
  "1FB0000000000Y": { kuerzel: "HAT", name: "Tobias Haas" }
  "1FB0000000001A": "BRA"
  # "1FB000000000DZ": { kuerzel: "MK" }
