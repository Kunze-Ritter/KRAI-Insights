# Techniker-Kürzel-Override (OPTIONAL) für das Service-Dashboard.
#
# Seit Migration 067 kommt der zugewiesene Techniker mit KLARNAMEN direkt aus Radix
# (employeeResponsible). Diese Datei wird nur noch gebraucht, wenn du statt des vollen
# Namens ein kurzes Kürzel zeigen willst — Schlüssel ist die `employeeIdResponsible`
# (die ID des VERANTWORTLICHEN Technikers, nicht des Arbeitszeit-/Lager-Loggers).
#
# Die IDs siehst du im Dashboard-Tab „Techniker-Profil" (Spalte techniker_id) oder via:
#   SELECT DISTINCT techniker_id, techniker FROM insights.vw_service_visits;
# Nach Änderungen laden:
#   docker exec krai-insights-app python -m insights.etl.load --technicians
#
# Format: employeeIdResponsible -> Kürzel  ODER  -> { kuerzel, name }

technicians:
  "1FB000000000H1": { kuerzel: "HAT", name: "Tobias Haas" }
  # "1FB0000000001A": "XYZ"
